__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.manifest
*.spec

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
pyvenv.cfg

# --- IDE / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.spyder-py3/
.vs/
*.code-workspace

# --- OS Files ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# --- Cache & Temp Files ---
*.cache
*.tmp
*.swp
*.swo
*~

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.log
secrets.py
auth.json
api_key.json
config.json

# --- Generated Data & Output ---
output/
data/
!output/.gitkeep
!data/.gitkeep
*.csv
*.xlsx
*.parquet

# --- AI Agent Context Files ---
CLAUDE.md
GEMINI.md
QWEN.md
REFACTORING.md
CONTRIBUTING.md
.claude/
.agent/
.qwen/
.gemini/
.cursor/
.devcontainer/

