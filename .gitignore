htmlcov/
.tox/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
nosetests.xml
pytestdebug.log

# --- Profiling & Debugging ---
*.prof
*.pyprof
.profile
.pytest_cache/
nosetests.xml

# --- Jupyter Notebooks ---
.ipynb_checkpoints
*.ipynb

# --- Local Development ---
# ⚠️ NUNCA subir: contiene work personal, logs sensibles, documentación temporal
local_work/
local_work/**/*
!local_work/.gitkeep
tmp/
temp/
*.tmp

# --- Pre-commit ---
.secrets.baseline
.pre-commit-cache/

# --- Ruff Cache ---
.ruff_cache/

